TG_BOT_TOKEN=1234567890:replace_with_your_real_token

# Logging
LOG_LEVEL=INFO

# OpenTelemetry (console exporters)
OTEL_SERVICE_NAME=tg-toolkit-bot
TRACE_ENABLED=true
METRICS_ENABLED=true
METRICS_EXPORT_INTERVAL_SEC=30

# Rate limit per (chat_id, user_id)
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW_SEC=60

# Optional allowlist; empty = everyone allowed
# ALLOWED_USER_IDS=123456789,987654321
